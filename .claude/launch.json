{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5173"],
      "cwd": "front-end",
      "port": 5173
    },
    {
      "name": "Backend (FastAPI local)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--reload", "--port", "8000"],
      "cwd": ".",
      "port": 8000
    }
  ]
}
